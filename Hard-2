#include <stdio.h>

int main() {
    int array[6];
    int index, i, j;
    int temp;
    
    // 1. Collect inputs safely using &
    for (index = 0; index < 6; index++) {
        printf("Enter a number: ");
        scanf(" %d", &temp); 
        array[index] = temp;
    }
    
    // 2. Correct Bubble Sort Nested Loops
    for (i = 0; i < 5; i++) {
        for (j = 0; j < 5 - i; j++) {
            if (array[j] > array[j + 1]) {
                // Swap elements
                temp = array[j];
                array[j] = array[j + 1];
                array[j + 1] = temp;
            }
        }
    }
    
    // 3. Print element by element
    printf("\nSorted array: ");
    for (index = 0; index < 6; index++) {
        printf("%d ", array[index]);
    }
    printf("\n");

    return 0;
}
